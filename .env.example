# EcoLearn Environment Config
# Copy this to .env and fill in your MySQL credentials.
# Railway deployment can also set these values in the Railway service Environment tab.

PORT=3001

# MySQL connection
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password_here
DB_NAME=ecolearn

# Change this to a long random string in production!
JWT_SECRET=ecolearn-super-secret-jwt-key-change-me-in-production
